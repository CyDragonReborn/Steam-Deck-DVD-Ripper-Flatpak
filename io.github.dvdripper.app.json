{
    "app-id": "io.github.dvdripper.app",
    "runtime": "org.gnome.Platform",
    "runtime-version": "46",
    "sdk": "org.gnome.Sdk",
    "command": "dvd-ripper",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=home",
        "--filesystem=host",
        "--filesystem=/run/media:create",
        "--filesystem=/media:create",
        "--filesystem=/mnt:create"
    ],
    "add-extensions": {
        "org.freedesktop.Platform.ffmpeg-full": {
            "directory": "lib/ffmpeg",
            "version": "24.08",
            "autodelete": false
        }
    },
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "lsdvd",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://sourceforge.net/projects/lsdvd/files/lsdvd/lsdvd-0.17/lsdvd-0.17.tar.bz2/download",
                    "sha256": "6c0e8a989e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e8e"
                }
            ]
        },
        {
            "name": "dvd-ripper",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --prefix=/app --no-deps .",
                "install -Dm644 data/io.github.dvdripper.app.desktop /app/share/applications/io.github.dvdripper.app.desktop",
                "install -Dm644 data/io.github.dvdripper.app.svg /app/share/icons/hicolor/scalable/apps/io.github.dvdripper.app.svg",
                "install -Dm644 data/io.github.dvdripper.app.metainfo.xml /app/share/metainfo/io.github.dvdripper.app.metainfo.xml"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
